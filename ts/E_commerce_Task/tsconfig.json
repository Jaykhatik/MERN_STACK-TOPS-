{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
     "allowJs": true,
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    "jsx": "react-jsx",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "types": ["vite/client"]
  },
  "include": ["src"]
}